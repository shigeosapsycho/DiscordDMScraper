# --- tokens (REQUIRED) ---
# Discord USER token of the account whose DMs you want to mirror.
# WARNING: using a user token for automation is a Discord ToS violation
# and can result in account suspension. Use only for personal archival.
CLIENT_TOKEN=

# Discord BOT token for posting into the destination server.
# Create a bot at https://discord.com/developers/applications and invite it
# to your destination server with "Manage Channels" + "Manage Webhooks".
SERVER_TOKEN=

# --- destination ---
DEST_GUILD_ID=
DMS_CATEGORY_NAME=DMs

# --- IPC (defaults are fine for docker-compose) ---
SERVER_WS_HOST=server
SERVER_WS_PORT=8765

# --- behavior ---
BACKFILL_CONCURRENCY=3
ATTACHMENT_MAX_BYTES=25000000
INCLUDE_GROUP_DMS=true

# --- admin dashboard ---
ADMIN_PORT=6767

# --- storage ---
DB_PATH=/data/data.db
